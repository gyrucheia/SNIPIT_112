<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true"
    android:scrollbars="none">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:fontFamily="monospace"
        android:text="Snap-to-Snip"
        android:textColor="@color/accent_green"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        android:lineSpacingMultiplier="1.3"
        android:text="Demo: simulates camera OCR — no cloud, no ML kit required for this build."
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_card">

        <TextView
            android:id="@+id/camera_placeholder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="📷 Tap “Scan board” below"
            android:textColor="@color/text_muted"
            android:textSize="13sp" />
    </FrameLayout>

    <TextView
        android:id="@+id/ocr_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:fontFamily="monospace"
        android:textColor="@color/accent_cyan"
        android:textSize="11sp" />

    <ProgressBar
        android:id="@+id/ocr_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginBottom="12dp"
        android:max="100"
        android:progress="0"
        android:progressTint="@color/accent_green"
        android:visibility="gone" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        android:fontFamily="monospace"
        android:text="EXTRACTED"
        android:textColor="@color/text_muted"
        android:textSize="10sp" />

    <EditText
        android:id="@+id/extracted_code"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:minHeight="200dp"
        android:background="@drawable/bg_code_block"
        android:fontFamily="monospace"
        android:gravity="top|start"
        android:hint="Extracted code appears here..."
        android:inputType="textMultiLine"
        android:minLines="5"
        android:padding="10dp"
        android:textColor="@color/accent_cyan"
        android:textSize="11sp" />

    <Button
        android:id="@+id/btn_scan"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_card"
        android:text="Scan board (simulated)"
        android:textColor="@color/text_primary" />

    <Button
        android:id="@+id/btn_save_extracted"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_button_green"
        android:enabled="false"
        android:text="Save to Vault"
        android:textColor="@color/black"
        android:textStyle="bold" />
</LinearLayout>
</ScrollView>
