<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Camera Section: Cinematic View -->
    <FrameLayout
        android:id="@+id/camera_section"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/guideline_h"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.camera.view.PreviewView
            android:id="@+id/previewView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Static Capture Preview (Hidden until capture) -->
        <ImageView
            android:id="@+id/capture_preview_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:background="@color/black" />

        <!-- High-Tech Overlay -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <View
                android:id="@+id/scrim_overlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#99000000" />

            <!-- The Targeting Frame -->
            <FrameLayout
                android:id="@+id/scanner_box"
                android:layout_width="260dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:background="@drawable/scanner_targeting_frame" />
        </FrameLayout>

        <!-- Floating Status Badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            android:background="@drawable/bg_status_badge"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/ic_circle_filled"
                android:backgroundTint="@color/terminal_green"
                android:layout_marginEnd="8dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SCANNER ACTIVE"
                android:textColor="@color/terminal_green"
                android:fontFamily="monospace"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>
        </LinearLayout>
    </FrameLayout>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_h"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.55" />

    <!-- Professional Control Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottom_card"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardBackgroundColor="@color/bg_secondary"
        app:cardCornerRadius="28dp"
        app:cardElevation="20dp"
        android:layout_marginTop="-30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/guideline_h">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="24dp">

            <TextView
                android:id="@+id/ocr_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SYSTEM READY"
                android:textColor="@color/text_secondary"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:letterSpacing="0.05"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ProgressBar
                android:id="@+id/ocr_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:layout_marginTop="12dp"
                android:indeterminate="true"
                android:indeterminateTint="@color/terminal_green"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/ocr_status" />

            <!-- The Code Result Box -->
            <FrameLayout
                android:id="@+id/result_container"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_terminal_window"
                app:layout_constraintTop_toBottomOf="@id/ocr_progress"
                app:layout_constraintBottom_toTopOf="@+id/btn_scan">

                <TextView
                    android:id="@+id/extracted_preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="16dp"
                    android:fontFamily="monospace"
                    android:textSize="12sp"
                    android:textColor="@color/cyber_blue"
                    android:hint="Captured source will appear here..."
                    android:textColorHint="@color/text_muted"
                    android:scrollbars="vertical"
                    android:gravity="top|start"/>
                
                <!-- Hint View -->
                <LinearLayout
                    android:id="@+id/scanner_hint_container"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp">
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_camera"
                        app:tint="@color/text_muted"
                        android:alpha="0.2"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ADJUST FRAME &amp; CAPTURE"
                        android:textColor="@color/text_muted"
                        android:fontFamily="monospace"
                        android:textSize="9sp"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>
            </FrameLayout>

            <LinearLayout
                android:id="@+id/btn_container_snap"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_scan"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="3"
                    android:layout_marginEnd="8dp"
                    android:text="START CAPTURE"
                    android:fontFamily="monospace"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    app:backgroundTint="@color/terminal_green"
                    app:cornerRadius="14dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_gallery_upload"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="2"
                    android:text="UPLOAD"
                    android:fontFamily="monospace"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/terminal_green"
                    app:strokeColor="@color/terminal_green"
                    app:cornerRadius="14dp" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_continue_to_editor"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="PROCEED TO EDITOR"
                android:fontFamily="monospace"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:visibility="gone"
                app:backgroundTint="@color/accent_purple"
                app:cornerRadius="14dp"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
