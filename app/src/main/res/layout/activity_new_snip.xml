<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/btn_cancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:text="← Back"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="@string/new_snip"
                android:textColor="@color/accent_green"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_share"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:text="@string/share"
                android:textColor="@color/accent_cyan"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:fontFamily="monospace"
            android:text="TITLE"
            android:textColor="@color/text_muted"
            android:textSize="10sp" />

        <EditText
            android:id="@+id/input_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_search"
            android:hint="My snippet"
            android:inputType="textCapSentences"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:fontFamily="monospace"
            android:text="LANGUAGE"
            android:textColor="@color/text_muted"
            android:textSize="10sp" />

        <AutoCompleteTextView
            android:id="@+id/input_language"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_search"
            android:completionThreshold="1"
            android:fontFamily="monospace"
            android:hint="@string/language_search_hint"
            android:inputType="text"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:fontFamily="monospace"
            android:text="TAGS"
            android:textColor="@color/text_muted"
            android:textSize="10sp" />

        <EditText
            android:id="@+id/input_tags"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_search"
            android:hint="#Java,#Firebase"
            android:inputType="text"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:fontFamily="monospace"
            android:text="CODE"
            android:textColor="@color/text_muted"
            android:textSize="10sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_fix_with_ai"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/fix_with_ai"
                android:textColor="@color/accent_green"
                app:strokeColor="@color/accent_green"
                app:cornerRadius="8dp"
                android:textSize="12sp" />

            <ProgressBar
                android:id="@+id/progress_fix_ai"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:indeterminate="true"
                android:visibility="gone" />
        </LinearLayout>

        <EditText
            android:id="@+id/input_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_code_block"
            android:fontFamily="monospace"
            android:gravity="top|start"
            android:hint="Paste code here..."
            android:inputType="textMultiLine|textNoSuggestions"
            android:minLines="8"
            android:padding="12dp"
            android:textColor="@color/accent_cyan"
            android:textColorHint="@color/text_muted"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/offline_ready"
            android:textColor="@color/accent_green"
            android:textSize="11sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_commit"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/commit_to_vault"
            android:textColor="@color/black"
            android:textStyle="bold"
            app:backgroundTint="@color/accent_green"
            app:cornerRadius="12dp" />
    </LinearLayout>
</ScrollView>
