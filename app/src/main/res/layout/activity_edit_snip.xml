<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/btn_cancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:text="← Back"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="@string/edit_snip_title"
                android:textColor="@color/accent_green"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_show_qr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:text="@string/show_qr"
                android:textColor="@color/accent_cyan"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:fontFamily="monospace"
            android:text="@string/editor_ide_hint"
            android:textColor="@color/text_muted"
            android:textSize="11sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:fontFamily="monospace"
            android:text="TITLE"
            android:textColor="@color/text_muted"
            android:textSize="10sp" />

        <EditText
            android:id="@+id/input_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_search"
            android:hint="My snippet"
            android:inputType="textCapSentences"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:fontFamily="monospace"
            android:text="LANGUAGE"
            android:textColor="@color/text_muted"
            android:textSize="10sp" />

        <AutoCompleteTextView
            android:id="@+id/input_language"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_search"
            android:completionThreshold="1"
            android:fontFamily="monospace"
            android:hint="@string/language_search_hint"
            android:inputType="text"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:fontFamily="monospace"
            android:text="TAGS"
            android:textColor="@color/text_muted"
            android:textSize="10sp" />

        <EditText
            android:id="@+id/input_tags"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_search"
            android:hint="#Java,#Firebase"
            android:inputType="text"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:fontFamily="monospace"
            android:text="CODE"
            android:textColor="@color/text_muted"
            android:textSize="10sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_fix_with_ai"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/bg_tag"
                android:text="@string/fix_with_ai"
                android:textColor="@color/accent_green"
                android:textSize="12sp" />

            <ProgressBar
                android:id="@+id/progress_fix_ai"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:indeterminate="true"
                android:visibility="gone" />
        </LinearLayout>

        <EditText
            android:id="@+id/input_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_code_block"
            android:fontFamily="monospace"
            android:gravity="top|start"
            android:hint="@string/editor_code_hint"
            android:inputType="textMultiLine|textNoSuggestions"
            android:minHeight="420dp"
            android:minLines="18"
            android:padding="14dp"
            android:scrollbars="vertical"
            android:textColor="@color/accent_cyan"
            android:textColorHint="@color/text_muted"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_delete"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card"
                android:text="@string/delete_snip"
                android:textColor="@color/accent_red"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_commit"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_green"
                android:text="@string/save_changes"
                android:textColor="@color/black"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
