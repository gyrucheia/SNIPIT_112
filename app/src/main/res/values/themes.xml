<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SnipIT" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/accent_green</item>
        <item name="colorPrimaryDark">@color/bg_primary</item>
        <item name="colorAccent">@color/accent_green</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_secondary</item>
    </style>

    <style name="Theme.SnipIT.Splash" parent="Theme.SnipIT">
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="SnipIT.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/accent_green</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="SnipIT.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/accent_green</item>
        <item name="android:textColor">@color/accent_green</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="SnipIT.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="TagChip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="android:textColor">@color/white</item>
        <item name="chipBackgroundColor">@color/bg_input</item>
        <item name="chipStrokeWidth">1dp</item>
    </style>

    <style name="PinDigit">
        <item name="android:layout_width">44dp</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:background">@drawable/bg_pin_digit</item>
        <item name="android:textColor">@color/accent_green</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:fontFamily">monospace</item>
    </style>
</resources>